{
  "version": 2,
  "builds": [
    {
      "src": "public/index.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "public/check.php",
      "use": "vercel-php@0.7.2"
    }
  ],
  "routes": [
    {
      "src": "/check.php",
      "dest": "/public/check.php"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
