{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE_WITH_RAILWAY_API_URL/api/:path*"
    },
    {
      "source": "/sanctum/:path*",
      "destination": "https://REPLACE_WITH_RAILWAY_API_URL/sanctum/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
