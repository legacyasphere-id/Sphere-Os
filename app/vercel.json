{
  "buildCommand": "npm run build-only",
  "outputDirectory": "dist",
  "installCommand": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sphere-os-l6ta.vercel.app/api/:path*"
    },
    {
      "source": "/sanctum/:path*",
      "destination": "https://sphere-os-l6ta.vercel.app/sanctum/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
